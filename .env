# ----- BETTER AUTH -----
# Secret này dùng để mã hóa Cookie và JWT bảo mật không ai giả mạo được (Bạn có thể gõ bừa một chuỗi kí tự lộn xộn cỡ 32 chữ cái tùy ý để làm khóa bí mật)
BETTER_AUTH_SECRET=xxxxxx
# Khai báo địa chỉ Website gốc, để khi User chạy từ mảng Appwrite cũ sang, BetterAuth biết để Redirect đúng chỗ
BETTER_AUTH_URL=https://backingscore.com

GOOGLE_CLIENT_ID=xxxxxx
GOOGLE_CLIENT_SECRET=xxxxxx

# TURSO D1 MIGRATION
TURSO_DATABASE_URL=xxxxx
TURSO_AUTH_TOKEN=xxxx
